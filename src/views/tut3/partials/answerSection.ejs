<style>
    .question-image {
        width: 100%;
        max-width: 500px;
    }

    .code-block {
        padding-top: 15px;
        padding-bottom: 15px;
    }

    .correct-line {
        font-family: monospace;
        font-size: 16px;
        background-color: rgba(10, 247, 3, 0.19);
    }
</style>

<div class="container pt-2" id="app">

    <h1>{{ questionConfig.name }}</h1>
    <div class="row">
        <div class="col-md-6">
            <img v-bind:src="questionConfig.image" alt="question" class="question-image"/>
        </div>
        <div class="col-md-6">
            <h3>Trace the Program</h3>
            <ul class="nav nav-tabs">
                <li class="nav-item" v-for="section, key in questionConfig.subsections">
                    <a class="nav-link"
                       v-bind:class="{ active: currentSection === key }"
                       v-on:click="currentSection = key; hasError = false; currentLine = ''"
                       href="javascript:void(0)"
                    >
                        Part {{ key + 1 }}
                        <span v-if="getAnswer(key).length === section.answer.length"> ✅ </span>
                    </a>
                </li>
            </ul>
            <small v-if="failedAttempts[currentSection]">Total failed attempts {{ failedAttempts[currentSection]
                }}</small>
            <p class="pt-2">{{ questionConfig.subsections[currentSection].description }}</p>
            <div class="code-block">
                <div class="correct-line" v-for="line in getAnswer(currentSection)">{{ line }}</div>
            </div>
            <div class="alert alert-danger" role="alert" v-if="hasError">
                That was not quite right... try again.
                <button type="button" class="close" v-on:click="hasError = false" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="input-group"
                 v-if="getAnswer(currentSection).length !== questionConfig.subsections[currentSection].answer.length">
                <input type="text" class="form-control" v-model="currentLine" v-on:keyup.enter="submitCurrentLine()"
                       placeholder="Next line of output...">
                <div class="input-group-append">
                    <button class="btn btn-secondary" v-on:click="submitCurrentLine()" type="button">Enter</button>
                </div>
            </div>
            <div class="alert alert-success"
                 v-if="getAnswer(currentSection).length === questionConfig.subsections[currentSection].answer.length"
                 role="alert">
                You have completed the part!
            </div>
            <hr/>
            <form method="post">
                <input type="hidden" name="response" v-bind:value="getSaveData()" />
                <button class="btn btn-primary">Save &amp; Go Back</button>
            </form>
        </div>
    </div>
</div>

<script>
    const EXISTING_RESPONSE = <%- response ? response : "null" %>;
</script>

<script src="<%= absRoute('/js/tut3/type-a.js') %>"></script>
