<style>
    .answer-textarea {
        height: calc(100vh - 170px) !important;
        font-family: monospace;
    }
</style>

<div class="col-md-6">
    <h3>Test Cases</h3>
    <p>Type your test cases below, the algorithm will automatically execute while you type.</p>
    <p>Yellow background denotes a failed test case.</p>

    <div id="testApp">
        <table class="table">
            <thead>
            <tr>
                <th scope="col">Input</th>
                <th scope="col">Expected Output</th>
                <th scope="col">Actual Output</th>
                <th scope="col"></th>
            </tr>
            </thead>
            <tbody>
                <tr v-for="testCase in testCases" v-bind:style="{ backgroundColor: testCase.expected.toString() !== algorithm(testCase.input).toString() ? 'yellow' : 'white' }">
                    <td>
                        <input class="form-control" v-model="testCase.input"/>
                    </td>
                    <td>
                        <input class="form-control" v-model="testCase.expected"/>
                    </td>
                    <td>
                        <input class="form-control" v-bind:value="algorithm(testCase.input)" disabled/>
                    </td>
                    <td>
                        <button class="btn btn-danger" v-on:click="removeTestCase(testCase)">Remove</button>
                    </td>
                </tr>
                <tr>
                    <td colspan="3"><button class="btn btn-secondary" v-on:click="addTestCase()">Add Test Case</button> </td>
                </tr>
            </tbody>
        </table>

        <form method="post" id="answer-form">
            <input type="hidden" name="response" v-bind:value="JSON.stringify(testCases)" />
            <button class="btn btn-primary mt-2">Submit</button>
        </form>

    </div>

</div>

<script>

    const storedCases = <%- response ? response : "[]" %>;

    const testApp = new Vue({
        el: "#testApp",
        data: {
            testCases: storedCases,
        },
        methods: {
            // INSERT ALGORITHM HERE
            algorithm: algorithm,

            addTestCase() {
                this.testCases.push({input: "", expected: ""});
            },

            removeTestCase(testCase) {
                this.testCases.splice(this.testCases.indexOf(testCase), 1);
            }
        }
    })
</script>
