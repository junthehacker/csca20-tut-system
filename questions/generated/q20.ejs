<script>
function palindrome() {
  var str = document.getElementById("box").value;
  var re = /[\W_]/g;
  var lowRegStr = str.toLowerCase().replace(re, '');
  var reverseStr = lowRegStr.split('').reverse().join('');
  if (reverseStr === lowRegStr){
    document.getElementById("answ").innerHTML = "true";
  } else {
    document.getElementById("answ").innerHTML = "false";
  }
}
</script>

<div id="q20">
    <h1>Question 20</h1>

    <p>Click on the button below to get the output. It might change depending on what you have entered:</p>
    <input type="text" id="box"/>
    <button onclick="palindrome()">?</button>

    <p> Output: <output id="answ"></output> </p>

</div>




